# Shared base — sourced by Brewfile##class.* via instance_eval

# Keep here just to make `brew bundle cleanup` work
brew "mas"
brew "yadm"
brew "mackup"

# GNU Core Utilities
brew "coreutils"
brew "binutils"
brew "findutils"
brew "moreutils"
brew "gnu-sed"
brew "gnu-tar"
brew "gnutls"
brew "gnupg"
brew "gzip"
brew "bash"
brew "lsof"

# Essential CLI tools
