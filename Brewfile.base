brew "zsh"
brew "wget"
brew "openssh"
brew "openssl"
brew "xz"
brew "zlib"
brew "git"
brew "git-lfs"
brew "gh"
brew "tig"
brew "jq"
brew "fzf"

# Modern Unix tools
